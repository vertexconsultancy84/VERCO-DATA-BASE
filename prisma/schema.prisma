// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// Fallback for local development when MongoDB is unavailable
// To use SQLite, comment out the above and uncomment below:
// datasource db {
//   provider = "sqlite"
//   url      = "file:./dev.db"
// }

enum ContactStatus {
  New
  InProgress
  Resolved
}

enum ProductCategory {
  RealEstate
  Food
  Rent
  OtherProducts
  Vehicles
  Industry
}

model Registration {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  companyName     String
  email           String   @unique
  tinNumber       String
  phoneNumber     String
  location        String
  selectedServices String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  phone     String?
  password  String
  approved  Boolean  @default(false) // Admin must approve before the user can log in
  category  String   @default("OtherProducts")
  province  String?
  district  String?
  sector    String?
  zone      String?
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  userId        String         @db.ObjectId
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description    String
  category      ProductCategory @default(OtherProducts)
  subcategory   String?        // Optional subcategory (for-rent, for-sale, etc.)
  propertyType  String?        // Optional property type (apartment, working-space, family-home, house-for-sale, land-for-building)
  price         Float?         // Optional price field
  latitude      Float?         // Optional latitude for location
  longitude     Float?         // Optional longitude for location
  province      String?        // Optional province for location
  district      String?        // Optional district for location
  sector        String?        // Optional sector for location
  village       String?        // Optional village for location
  zone          String?        // Optional zone/neighborhood for location
  available     Boolean        @default(true) // Product availability status
  hidden        Boolean        @default(false) // Admin can hide products from public view
  contactNumber String?        // Optional contact number for this product
  whatsappNumber String?       // Optional WhatsApp number for this product
  ownerFullName  String?       // Details for Lease Agreement
  ownerNationality String?     // Details for Lease Agreement
  ownerID        String?       // Details for Lease Agreement
  ownerAddress   String?       // Details for Lease Agreement
  media         ProductMedia[]
  orders        Order[]         // Orders for this product
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProductMedia {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId    String   @unique @db.ObjectId
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  images       String[] // Array of Cloudinary URLs
  videos       String[] // Array of Cloudinary URLs
  mainImage    String? // Primary image URL
  mainVideo    String? // Primary video URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contact {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String?
  message   String
  status    ContactStatus @default(New)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Team {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  position  String
  image     String   // base64 encoded image
  order     Int      @default(0) // for ordering team members
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  productId     String   @db.ObjectId
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productTitle  String
  productPrice  Float
  quantity       Int      @default(1) // Number of items ordered
  userId        String?  @db.ObjectId // Optional for guest orders
  userName      String
  userEmail     String
  customerPhone String?
  deliveryAddress String?
  village        String?
  deliveryInstructions String?
  paymentMethod String?
  category      String
  subcategory   String?
  status        String   @default("pending") // pending, confirmed, preparing, out_for_delivery, delivered, cancelled
  paymentStatus String   @default("pending") // pending, paid, verified, failed
  paymentVerifiedBy String? @db.ObjectId // Admin who verified payment
  paymentVerifiedAt DateTime? // When payment was verified
  fulfillmentMethod String? @default("delivery") // "pickup" or "delivery"
  saleChannel   String?  @default("online") // "online" (placed through the site) or "manual" (recorded in person)
  deliveryPersonName String? // Name of person who will deliver / receive the order
  contractUploaded Boolean @default(false) // Whether signed contract has been uploaded
  contractFileUrl String? // URL to uploaded signed contract
  contractSubmittedAt DateTime? // When contract was submitted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IndustryCalculation {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String   @db.ObjectId
  rawMaterialName        String
  feedQuantity           Float    @default(0)
  pricePerUnit           Float    @default(0)
  autoFeedPrice          Float    @default(0)
  extraFeeds             Json     @default("[]")
  totalTaxes             Float    @default(0)
  commission             Float    @default(0)
  labourCost             Float    @default(0)
  totalTransport         Float    @default(0)
  otherExpenses          Float    @default(0)
  totalQty               Float    @default(0)
  qtyProducedBoxes       Float    @default(0)
  qtyProduced            Float    @default(0)
  possibleDiscount       Float    @default(0)
  calculatedPricePerUnit Float    @default(0)
  calculatedPricePerBox  Float    @default(0)
  totalFeedsPrice        Float    @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model FinishedProductCalculation {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String   @db.ObjectId
  productName            String?
  purchasePrice          Float    @default(0)
  transport              Float    @default(0)
  taxes                  Float    @default(0)
  packaging              Float    @default(0)
  labor                  Float    @default(0)
  otherExpenses          Float    @default(0)
  customExpenses         Json     @default("[]")
  desiredProfitPct       Float    @default(20)
  totalCost              Float    @default(0)
  recommendedSellingPrice Float   @default(0)
  actualSellingPrice     Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model IndustryProductAnalytics {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  month     String   // "YYYY-MM"
  rows      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IndustryStock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  items     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RawMaterialStock {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  materialName      String
  quantityPurchased Float
  unit              String
  purchasePrice     Float    @default(0)
  tax               Float    @default(0)
  transportCost     Float    @default(0)
  otherExpenses     Float    @default(0)
  customExpenses    Json     @default("[]")
  totalCost         Float    @default(0)
  costPerUnit       Float    @default(0)
  currentStock      Float    @default(0)
  createdAt         DateTime @default(now())
}

model FinishedProductStock {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String   @db.ObjectId
  productName          String
  quantityProduced     Float
  productionCost       Float    @default(0)
  laborCost            Float    @default(0)
  packagingCost        Float    @default(0)
  transportCost        Float    @default(0)
  otherExpenses        Float    @default(0)
  customExpenses       Json     @default("[]")
  totalProductionCost  Float    @default(0)
  costPerUnit          Float    @default(0)
  createdAt            DateTime @default(now())
}

model StockMovement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        String   // "raw" | "finished"
  recordId    String   @db.ObjectId
  recordName  String
  unit        String
  movement    String   // "in" | "out"
  quantity    Float
  notes       String?
  date        DateTime
  createdAt   DateTime @default(now())
}

model SiteVisitor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ip        String?
  userAgent String?
  page      String   @default("/")
  referrer  String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId   // recipient user
  title     String?                  // optional short subject
  message   String                   // body of the message from the admin
  read      Boolean  @default(false) // whether the user has opened it
  createdAt DateTime @default(now())
}

// Public site-wide announcement shown on the home page to all visitors.
model Announcement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  message   String
  active    Boolean  @default(true) // admin can show/hide without deleting
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contract {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  productId         String   @db.ObjectId
  productTitle      String
  productPrice      Float
  tenantName        String
  tenantNationality String?
  tenantID          String?
  tenantAddress     String?
  tenantContact     String?
  userName          String
  userEmail         String
  customerPhone     String?
  deliveryAddress   String?
  village           String?
  category          String
  subcategory       String?
  contractFileUrl   String?
  status            String   @default("pending")
  submittedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
