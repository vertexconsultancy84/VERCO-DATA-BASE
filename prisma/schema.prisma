// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  New
  InProgress
  Resolved
}

enum ProductCategory {
  RealEstate
  Food
  Rent
  OtherProducts
}

model Registration {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  companyName     String
  email           String   @unique
  tinNumber       String
  phoneNumber     String
  location        String
  selectedServices String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  phone      String?  // Optional phone number for WhatsApp contact
  password  String
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  userId        String         @db.ObjectId
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description    String
  category      ProductCategory @default(OtherProducts)
  price         Float?         // Optional price field
  latitude      Float?         // Optional latitude for location
  longitude     Float?         // Optional longitude for location
  province      String?        // Optional province for location
  district      String?        // Optional district for location
  sector        String?        // Optional sector for location
  village       String?        // Optional village for location
  available     Boolean        @default(true) // Product availability status
  hidden        Boolean        @default(false) // Admin can hide products from public view
  contactNumber String?        // Optional contact number for this product
  whatsappNumber String?       // Optional WhatsApp number for this product
  media         ProductMedia[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProductMedia {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId    String   @db.ObjectId
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  images       String[] // Array of Cloudinary URLs
  videos       String[] // Array of Cloudinary URLs
  mainImage    String? // Primary image URL
  mainVideo    String? // Primary video URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contact {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String?
  message   String
  status    ContactStatus @default(New)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Team {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  position  String
  image     String   // base64 encoded image
  order     Int      @default(0) // for ordering team members
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

